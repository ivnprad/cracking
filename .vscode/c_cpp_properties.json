{
    "configurations": [
      {
        "name": "Mac",
        "includePath": [
          "${workspaceFolder}/**",
          //"/usr/local/include",             // Common Boost location if installed via Homebrew
          "/opt/homebrew/include"           // For Apple Silicon (M1/M2/M3)
        ],
        "defines": [],
        "macFrameworkPath": [
          "/System/Library/Frameworks",
          "/Library/Frameworks"
        ],
        "compilerPath": "/usr/bin/clang++",
        "cStandard": "c11",
        "cppStandard": "c++23",
        "intelliSenseMode": "macos-clang-arm64" // Or x64, depending on your architecture
      }
    ],
    "version": 4
  }
  